    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "1.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
