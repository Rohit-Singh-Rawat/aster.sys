{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun scripts/validate-registry.ts && shadcn build && next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "registry:build": "bun scripts/validate-registry.ts && shadcn build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit",
    "check": "bun scripts/validate-registry.ts && biome check && bun run typecheck && vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@toolwind/corner-shape": "^0.0.8-3",
    "agentation": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hugeicons-react": "^0.4.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
